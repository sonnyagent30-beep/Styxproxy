# ============================================
# Bunche — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================

# ============================================
# POSTGRESQL
# ============================================
# Self-hosted on VPS. Created during PostgreSQL setup.
# See: docs/ARCHITECTURE_PLAN.md → Phase 1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bunche
POSTGRES_USER=bunche
# Strong password — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=***

# ============================================
# REDIS
# ============================================
# Self-hosted on VPS. Used for caching, sessions, rate limiting.
# See: docs/ARCHITECTURE_PLAN.md → Phase 1

REDIS_HOST=localhost
REDIS_PORT=6379
# Strong password — generate with: openssl rand -base64 32
REDIS_PASSWORD=***

# ============================================
# N8N (Workflow Engine)
# ============================================
# Self-hosted on VPS via Docker.
# See: docs/BUILD_PACKAGE.md → Week 1

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=***

# Bunche runs on a custom port (not default 5678) to avoid conflict
N8N_PORT=5679
N8N_PROTOCOL=https
# Your domain — used for webhook URLs in WhatsApp/Flutterwave
N8N_HOST=yourdomain.com

# ============================================
# MINIMAX M2 (LLM)
# ============================================
# Cloud LLM — replaces Ollama (local). API-compatible with OpenAI.
# Sign up: console.minimax.chat
# Cost: ~$0.001/msg at normal usage
# See: docs/ARCHITECTURE_PLAN.md → Phase 8

MINIMAX_API_KEY=***
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2

# ============================================
# WHATSAPP (Meta WhatsApp Business API)
# ============================================
# Receive and send WhatsApp messages.
# Apply: business.whatsapp.com → Get Started
# Alternative (easier): Twilio WhatsApp → twilio.com/whatsapp
# See: docs/FLUTTERWAVE_WHATSAPP_SETUP.md → Part 2

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=***
WHATSAPP_ACCESS_TOKEN=***
WHATSAPP_APP_SECRET=***

# Twilio WhatsApp (if using Option B instead)
TWILIO_ACCOUNT_SID=***
TWILIO_AUTH_TOKEN=***
TWILIO_WHATSAPP_FROM=+***

# Verify token — set this in Meta Business Console AND here
# Must match exactly on both sides
WHATSAPP_VERIFY_TOKEN=***

# ============================================
# FLUTTERWAVE (Payments)
# ============================================
# Nigerian payment processor — accepts transfer, card, USSD, QR.
# Sign up:rave.flutterwave.com
# Fee: 1.5% per transaction
# Webhook URL to set in dashboard: https://yourdomain.com/webhook/flutterwave
# See: docs/FLUTTERWAVE_WHATSAPP_SETUP.md → Part 1

FLUTTERWAVE_PUBLIC_KEY=***
FLUTTERWAVE_SECRET_KEY=***
FLUTTERWAVE_ENCRYPTION_KEY=***
# Must match exactly what you set in Flutterwave dashboard
FLUTTERWAVE_WEBHOOK_VERIF_HASH=***

# ============================================
# PROXY-SELLER (ISP + Datacenter Provider)
# ============================================
# Primary proxy provider — ISP and DC proxies.
# Sign up: proxy-seller.com → Reseller account
# API docs: api.proxy-seller.com/docs
# See: docs/PROVIDER_SETUP_GUIDE.md → Section 1

PROXY_SELLER_API_KEY=***

# ============================================
# DATAIMPULSE (Residential + Mobile Provider)
# ============================================
# Secondary proxy provider — Residential and Mobile 4G proxies.
# Sign up: dataimpulse.com
# Note: Credit never expires.
# See: docs/PROVIDER_SETUP_GUIDE.md → Section 3

DATAIMPULSE_API_KEY=***

# ============================================
# R2 (File Storage — for screenshots, PDFs)
# ============================================
# Cloudflare R2 — $0/month for 10GB. Used for ban screenshots, receipts.
# Alternative: AWS S3, Backblaze B2
# Sign up: dash.cloudflare.com → R2

R2_ACCOUNT_ID=***
R2_ACCESS_KEY_ID=***
R2_SECRET_ACCESS_KEY=***
R2_BUCKET_NAME=bunche-files
# Public bucket URL for accessing stored files
R2_PUBLIC_URL=https://pub-***.r2.dev

# ============================================
# TOTP (Admin 2FA)
# ============================================
# 64-character hex key for encrypting TOTP secrets.
# Generate with: openssl rand -hex 32
# See: docs/SECURITY_PLAN.md → Layer 6

TOTP_ENCRYPTION_KEY=***

# ============================================
# ADMIN
# ============================================
# Your admin WhatsApp number — used to identify admin commands.
# Format: country code + number, no spaces or symbols
# Example: 2348012345678

ADMIN_PHONE=***

# Admin PIN — bcrypt hash of the PIN.
# NEVER store the plain PIN.
# To generate hash (Node.js):
#   const bcrypt = require('bcrypt');
#   bcrypt.hash('YOUR_PIN', 10).then(hash => console.log(hash));
ADMIN_PIN_HASH=***

# ============================================
# DOMAIN + SSL
# ============================================
# Your registered domain pointing to the VPS IP.
# Buy: Namecheap, Cloudflare, Porkbun

DOMAIN=yourdomain.com
# VPS IP address — from your hosting provider
VPS_IP=***

# ============================================
# BACKUP (pg_dump + R2)
# ============================================
# Daily backup destination.
# See: docs/ARCHITECTURE_PLAN.md → Backup Strategy

BACKUP_RCLONE_PROFILE=r2-bunche
# Local backup directory (before uploading to R2)
BACKUP_DIR=/backup/bunche
# How many days to keep local backups
BACKUP_RETENTION_DAYS=30

# ============================================
# RATE LIMITING (Redis Keys TTL)
# ============================================
# Adjust these based on traffic volume.
# See: docs/SECURITY_PLAN.md → Layer 5

# Customer message rate limit window (seconds)
RATE_LIMIT_WINDOW_SECONDS=60
# Max messages per window per customer
RATE_LIMIT_MAX_MESSAGES=20

# Admin session TTL (seconds) — 30 minutes
ADMIN_SESSION_TTL_SECONDS=1800
# Fresh PIN TTL (seconds) — 2 minutes
FRESH_PIN_TTL_SECONDS=120
# Webhook idempotency TTL (seconds) — 24 hours
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400

# ============================================
# ALERTING
# ============================================
# Thresholds that trigger admin alerts.
# See: docs/SECURITY_PLAN.md → Layer 7

# Min revenue per day before alerting (₦)
ALERT_MIN_DAILY_REVENUE=50000
# Max errors per hour before alerting
ALERT_MAX_ERRORS_PER_HOUR=5
# Provider consecutive failures before alerting
ALERT_PROVIDER_CONSECUTIVE_FAILURES=3
