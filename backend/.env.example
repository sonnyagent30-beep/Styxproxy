# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/styxproxy
# Redis
REDIS_URL=redis://localhost:6379/0
# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
# Admin
ADMIN_TOKEN=your-admin-token-change-in-production
# Flutterwave
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret
# WhatsApp
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
# Minimax
MINIMAX_API_KEY=your-minimax-api-key
# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# CORS
CORS_ORIGINS=http://localhost:3000,https://styxproxy.com,https://styxproxy.com
# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
# Logging
LOG_LEVEL=INFO
