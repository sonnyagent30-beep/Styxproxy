# Styxproxy — Local Development Environment
# Safe defaults for local development.
# Override with real values when testing payment/webhook integrations.

# Database
POSTGRES_DB=styxproxy
POSTGRES_USER=styxproxy
POSTGRES_PASSWORD=styxproxy

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — weak default for local dev ONLY
JWT_SECRET=dev-secret-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin — weak default for local dev ONLY
ADMIN_TOKEN=dev-admin-token

# Flutterwave — leave empty
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# WhatsApp — leave empty
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Minimax — leave empty
MINIMAX_API_KEY=

# Logging
LOG_LEVEL=DEBUG
NEXT_PUBLIC_API_URL=https://api.styxproxy.com
