import { MetadataRoute } from 'next';

export default function robots(): MetadataRoute.Robots {
  return {
    rules: [
      {
        userAgent: '*',
        allow: '/',
        disallow: ['/admin/', '/api/', '/preview/', '/manage/'],
      },
    ],
    sitemap: 'https://styxproxy.com/sitemap.xml',
  };
}
