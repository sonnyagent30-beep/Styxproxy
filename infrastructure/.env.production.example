# ─────────────────────────────────────────────────────────────
# Styxproxy — Production Environment Variables
# Copy to .env before running docker compose
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=styxproxy
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_64
POSTGRES_DB=styxproxy

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_64

# ── PgBouncer ──────────────────────────────────────────────
# n8n connects via PgBouncer. FastAPI connects directly (asyncpg).
# Generate userlist.txt: echo '"styxproxy" "styxproxy"' > userlist.txt

# ── Application ─────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=CHANGE_ME
WHATSAPP_ACCESS_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY

# ── Security ─────────────────────────────────────────────────
# Admin token for /powerhold — generate with: openssl rand -base64 32
ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_64

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://styxproxy.com,https://api.styxproxy.com

# ── Domain ───────────────────────────────────────────────────
DOMAIN=styxproxy.com
API_DOMAIN=api.styxproxy.com
N8N_DOMAIN=n8n.styxproxy.com

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME

# ── Sentry — Error Tracking + APM ───────────────────────────
# Self-hosted Sentry (docker compose includes sentry service)
# Generate secret key with: openssl rand -hex 64
SENTRY_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_64
SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/1234567
SENTRY_ORG=Styxproxy
SENTRY_PROJECT=styxproxy-api
SENTRY_PROJECT_N8N=styxproxy-n8n
# Environments: development | staging | production
SENTRY_ENVIRONMENT=production

# Performance monitoring sample rates (0.0 = off, 1.0 = 100%)
# Set to 0.1 (10%) in production to control Sentry quota costs
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Sentry Docker image version (pin to a release for reproducibility)
# Check: https://github.com/getsentry/self-hosted/releases
SENTRY_VERSION=latest

# ── Backup ───────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_64
BACKUP_DESTINATION=rclone:styxproxy-backups
