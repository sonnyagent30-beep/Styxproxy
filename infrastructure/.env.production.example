# ─────────────────────────────────────────────────────────────
# Bunche — Production Environment Variables
# Copy to .env before running docker compose
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=bunche
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_64
POSTGRES_DB=bunche

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_64

# ── Application ─────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=CHANGE_ME
WHATSAPP_ACCESS_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY

# ── Security ─────────────────────────────────────────────────
# Admin token for /powerhold — generate with: openssl rand -base64 32
ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_64

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://bunche.ng,https://api.bunche.ng

# ── Domain ───────────────────────────────────────────────────
DOMAIN=bunche.ng
API_DOMAIN=api.bunche.ng
N8N_DOMAIN=n8n.bunche.ng

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME

# ── Backup ───────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_64
BACKUP_DESTINATION=rclone:bunche-backups
